    max-width: 100%;
    height: auto;
    margin-top: 10px;
}


.elb-no-liveblog-entries-message{
	display:none!important;
}


/* Container de la mini-timeline */
.ul_elb_timeline {
    list-style: none;
    padding: 0;
    margin: 25px 0;
    background: linear-gradient(to right, #f8f9fa, #fff);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

/* Chaque élément de la timeline */
.elb-liveblog-timeline {
    padding: 15px 20px;
    margin: 0;
    border-left: 4px solid #87c220;
    border-bottom: none;
    font-size: 14px;
    line-height: 1.8;
    transition: all 0.3s ease;
    list-style: none; /* ← Enlève le point noir */
}

/* Point coloré */
.elb-liveblog-timeline:before {
    content: "●";
    color: #87c220;
    font-size: 18px;
    margin-right: 10px;
    font-weight: bold;
}

/* Hover effect */
.elb-liveblog-timeline:hover {
    background: #f0f9e8;
    padding-left: 25px;
    border-left-width: 6px;
}




/**/
 .live-badge {
            display: inline-flex;
            align-items: center;
            background-color: transparent;
            padding: 8px 12px;
	 margin:5px 0px;
            border-radius: 4px;
            font-weight: 900;
            font-size: 14px;
            gap: 6px;
            animation: switchStyle 3s ease-in-out infinite;
        }

        @keyframes switchStyle {
            0%, 48% {
                background-color: transparent;
            }
            50%, 98% {
                background-color: #FF0000;
            }
            100% {
                background-color: transparent;
            }
        }

    .live-badge    .circle-indicator {
            display: flex;
            align-items: center;
            gap: 3px;
            animation: toggleCircles 3s ease-in-out infinite;
        }

        @keyframes toggleCircles {
            0%, 100% {
                opacity: 1;
            }
        }

     .live-badge    .circle-indicator   .circle {
            width: 8px;
            height: 8px;
            background-color: #FF0000;
            border-radius: 50%;
            animation: blinkAndChangeColor 3s ease-in-out infinite;
        }

    .live-badge    .circle-indicator    .circle:nth-child(1) {
            animation-delay: 0s;
        }

    .live-badge    .circle-indicator    .circle:nth-child(2) {
            animation-delay: 0.15s;
        }

        @keyframes blinkAndChangeColor {
            0%, 23% {
                opacity: 1;
                background-color: #FF0000;
            }
            24%, 48% {
                opacity: 0.3;
                background-color: #FF0000;
            }
            49%, 50% {
                opacity: 0;
                background-color: #FF0000;
            }
            50%, 98% {
                opacity: 1;
                background-color: #FFF;
            }
            100% {
                opacity: 1;
                background-color: #FF0000;
            }
        }

   .live-badge    .live-text {
            color: #FF0000;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            animation: switchTextColor 3s ease-in-out infinite;
        }

        @keyframes switchTextColor {
            0%, 48% {
                color: #FF0000;
            }
            50%, 98% {
                color: #FFF;
            }
            100% {
                color: #FF0000;
            }
        }		</style>
