document.addEventListener('DOMContentLoaded', function() {
	
	  document.querySelectorAll('div.box_lien > a').forEach(function(link) {
        const originalHref = link.getAttribute('href');

        // On vide le href pour éviter la redirection immédiate
        link.setAttribute('href', '');

        // Ajout de l'événement clic
        link.addEventListener('click', function(e) {
            e.preventDefault();

            // Définir le cookie tn_lang=fr pour 30 jours
            document.cookie = "tn_lang=fr; path=/; domain=.tunisienumerique.com; max-age=" + (60 * 60 * 24 * 30);

            // Redirection manuelle après courte pause
            setTimeout(function() {
                window.location.href = originalHref;
            }, 20);
        });
    });
    document.querySelectorAll('li.menu-francais > a').forEach(function(link) {
        const originalHref = link.getAttribute('href');

        // On vide le href pour éviter la redirection immédiate
        link.setAttribute('href', '');

        // Ajout de l'événement clic
        link.addEventListener('click', function(e) {
            e.preventDefault();

            // Définir le cookie tn_lang=fr pour 30 jours
            document.cookie = "tn_lang=fr; path=/; domain=.tunisienumerique.com; max-age=" + (60 * 60 * 24 * 30);

            // Redirection manuelle après courte pause
            setTimeout(function() {
                window.location.href = originalHref;
            }, 20);
        });
    });
});
</script>


